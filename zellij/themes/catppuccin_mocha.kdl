// *Template*: `@pal_NAME_rgb@` placeholders (space-separated R G B
// triples) are substituted at build time from lib/palette.nix via
// lib/zellij.nix#substitutePalette. Edit by referencing palette
// names — never inline literal RGB triples.
themes {
    catppuccin_mocha {
        text_unselected {
            base @pal_text_rgb@
            background @pal_mantle_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        text_selected {
            base @pal_text_rgb@
            background @pal_surface2_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        ribbon_selected {
            base @pal_mantle_rgb@
            background @pal_green_rgb@
            emphasis_0 @pal_red_rgb@
            emphasis_1 @pal_peach_rgb@
            emphasis_2 @pal_pink_rgb@
            emphasis_3 @pal_blue_rgb@
        }
        ribbon_unselected {
            base @pal_mantle_rgb@
            background @pal_text_rgb@
            emphasis_0 @pal_red_rgb@
            emphasis_1 @pal_text_rgb@
            emphasis_2 @pal_blue_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        table_title {
            base @pal_green_rgb@
            background @pal_crust_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        table_cell_selected {
            base @pal_text_rgb@
            background @pal_surface2_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        table_cell_unselected {
            base @pal_text_rgb@
            background @pal_mantle_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        list_selected {
            base @pal_text_rgb@
            background @pal_surface2_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        list_unselected {
            base @pal_text_rgb@
            background @pal_mantle_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_green_rgb@
            emphasis_3 @pal_pink_rgb@
        }
        frame_selected {
            base @pal_green_rgb@
            background @pal_crust_rgb@
            emphasis_0 @pal_peach_rgb@
            emphasis_1 @pal_sapphire_rgb@
            emphasis_2 @pal_pink_rgb@
            emphasis_3 @pal_crust_rgb@
        }
        frame_unselected {
            base @pal_surface1_rgb@
            background @pal_base_rgb@
            emphasis_0 @pal_surface0_rgb@
            emphasis_1 @pal_surface0_rgb@
            emphasis_2 @pal_surface0_rgb@
            emphasis_3 @pal_surface0_rgb@
        }
        frame_highlight {
            base @pal_peach_rgb@
            background @pal_crust_rgb@
            emphasis_0 @pal_pink_rgb@
            emphasis_1 @pal_peach_rgb@
            emphasis_2 @pal_peach_rgb@
            emphasis_3 @pal_peach_rgb@
        }
        exit_code_success {
            base @pal_green_rgb@
            background @pal_crust_rgb@
            emphasis_0 @pal_sapphire_rgb@
            emphasis_1 @pal_mantle_rgb@
            emphasis_2 @pal_pink_rgb@
            emphasis_3 @pal_blue_rgb@
        }
        exit_code_error {
            base @pal_red_rgb@
            background @pal_crust_rgb@
            emphasis_0 @pal_yellow_rgb@
            emphasis_1 @pal_crust_rgb@
            emphasis_2 @pal_crust_rgb@
            emphasis_3 @pal_crust_rgb@
        }
        multiplayer_user_colors {
            player_1 @pal_pink_rgb@
            player_2 @pal_blue_rgb@
            player_3 @pal_crust_rgb@
            player_4 @pal_yellow_rgb@
            player_5 @pal_sapphire_rgb@
            player_6 @pal_crust_rgb@
            player_7 @pal_red_rgb@
            player_8 @pal_crust_rgb@
            player_9 @pal_crust_rgb@
            player_10 @pal_crust_rgb@
        }
    }
}
