{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "primary": "@pal_primary@",
    "muted": "@pal_muted@",
    "accent": "@pal_accent@",
    "branch": "@pal_branch@",
    "success": "@pal_success@",
    "warning": "@pal_warning@",
    "error": "@pal_error@"
  },
  "blocks": [
    {
      "alignment": "left",
      "type": "prompt",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:primary",
          "template": "{{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:accent",
          "template": "{{ $segs := splitList \"/\" .Path }}{{ $n := len $segs }}{{ if le $n 4 }}{{ .Path }}{{ else }}{{ index $segs 0 }}/{{ index $segs 1 }}/{{ index $segs 2 }}//{{ index $segs (sub $n 1) }}{{ end }} ",
          "properties": {
            "home_icon": "~",
            "style": "full"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:branch",
          "template": "{{ .HEAD }}{{ if .Hash }} {{ trunc 4 .Hash }}{{ end }}",
          "properties": {
            "branch_icon": "",
            "cherry_pick_icon": "",
            "commit_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": false,
            "merge_icon": "",
            "no_commits_icon": "",
            "rebase_icon": "",
            "revert_icon": "",
            "tag_icon": ""
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:success",
          "template": "{{ if or (gt .Staging.Added 0) (gt .Working.Untracked 0) }} {{ add .Staging.Added .Working.Untracked }}{{ end }}",
          "properties": { "fetch_status": true }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:warning",
          "template": "{{ if or (gt .Staging.Modified 0) (gt .Working.Modified 0) }} {{ add .Staging.Modified .Working.Modified }}{{ end }}",
          "properties": { "fetch_status": true }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:error",
          "template": "{{ if or (gt .Staging.Deleted 0) (gt .Working.Deleted 0) }} {{ add .Staging.Deleted .Working.Deleted }}{{ end }}",
          "properties": { "fetch_status": true }
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:muted",
          "template": " ❯"
        }
      ]
    }
  ],
  "final_space": true,
  "version": 4
}
